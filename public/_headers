# JS/CSS は Vite がコンテンツハッシュ付きファイル名を生成するため長期キャッシュ可
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML は常に最新を返す（SPA のエントリーポイント）
/*.html
  Cache-Control: no-cache

/*
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://i.ytimg.com https://img.youtube.com; connect-src 'self' https://cloudflareinsights.com https://wlsahwinqoajqmrkabqo.supabase.co

  # -------------------------------------------------------
  # CSP 追加ルール（新しいリソースを使うときはここを更新）
  # -------------------------------------------------------
  # ローカルフォント（public/resources/fonts/）→ font-src に 'self' 必須
  # 外部画像（YouTube以外）       → img-src に追加
  # 外部APIドメイン               → connect-src に追加
  # 外部スクリプト                → script-src に追加
  #
  # AdSense導入時は以下をCSPに追加:
  #   script-src に: https://pagead2.googlesyndication.com https://partner.googleadservices.com
  #   frame-src に:  https://googleads.g.doubleclick.net https://tpc.googlesyndication.com
  #   connect-src に: https://pagead2.googlesyndication.com
